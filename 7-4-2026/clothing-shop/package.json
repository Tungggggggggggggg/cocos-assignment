{
  "name": "clothing-shop-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:api": "cd apps/api && npm run build",
    "build:admin": "cd apps/admin && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build": "npm run build:api && npm run build:admin && npm run build:web",
    "lint": "npm run lint:api && npm run lint:admin && npm run lint:web",
    "lint:api": "cd apps/api && npm run lint",
    "lint:admin": "cd apps/admin && npm run lint",
    "lint:web": "cd apps/web && npm run lint"
  }
}
